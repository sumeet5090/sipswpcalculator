{
    "require": {
        "dompdf/dompdf": "^2.0",
        "erusev/parsedown": "^1.8"
    },
    "autoload": {
        "psr-4": {
            "": "src/"
        },
        "files": [
            "functions.php"
        ]
    },
    "require-dev": {
        "phpunit/phpunit": "^13.2",
        "phpstan/phpstan": "^2.2",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse --memory-limit=-1",
        "phpcs": "phpcs",
        "phpcbf": "phpcbf",
        "check-all": [
            "@phpstan",
            "@phpcs",
            "@test"
        ]
    }
}
